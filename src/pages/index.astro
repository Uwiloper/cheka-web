---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cheka | Valida tus yapeos en automático">
  <Header />
  
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 mt-16">
    <div class="text-center space-y-4">
      <span class="text-xs font-bold uppercase tracking-widest text-cheka-primary bg-cheka-primary/10 px-3 py-1 rounded-full">
        Beta disponible
      </span>
      <h1 class="text-5xl md:text-6xl font-black tracking-tight text-slate-900 dark:text-white mt-6">
        Tus pagos validados <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cheka-primary to-emerald-400">
          en automático.
        </span>
      </h1>
      <p class="text-slate-500 dark:text-slate-400 max-w-xl mx-auto text-lg mt-4">
        Elimina el error humano y el fraude en tus pagos digitales. Cheka conecta tus dispositivos Android con un panel web inteligente para monitorear Yape, Plin, Sipe, BBVA, BCP y más en tiempo real.
      </p>
    </div>
  </main>
</Layout>