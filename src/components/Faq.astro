---
// src/components/Faq.astro
import faqData from '../data/faq.json';
const { header, categories, faqs } = faqData;
---

<section id="faq" class="py-20 md:py-32 bg-white dark:bg-[#0A0F1C] transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12 md:mb-16 text-center md:text-left">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 dark:text-white tracking-tight mb-4">
        {header.title}
      </h2>
      <p class="text-base md:text-lg text-slate-600 dark:text-[#94a3b8]">
        {header.description}
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 items-start">
      
      <aside class="w-full lg:w-1/4 shrink-0">
        <div class="flex lg:flex-col gap-2 overflow-x-auto no-scrollbar pb-4 lg:pb-0 snap-x">
          
          <button 
            class="cat-btn group flex items-center justify-between px-5 py-3 rounded-xl font-bold text-sm transition-all duration-300 snap-start shrink-0 text-left border bg-[#10b981]/10 text-[#10b981] border-[#10b981]/20"
            data-target="all"
          >
            <span>Todos</span>
            <svg class="w-4 h-4 hidden lg:block transition-all duration-300 arrow-icon opacity-100 translate-x-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
          </button>

          {categories.map((cat) => (
            <button 
              class="cat-btn group flex items-center justify-between px-5 py-3 rounded-xl font-bold text-sm transition-all duration-300 snap-start shrink-0 text-left border border-transparent text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5"
              data-target={cat.id}
            >
              <span>{cat.name}</span>
              <svg class="w-4 h-4 hidden lg:block transition-all duration-300 arrow-icon opacity-0 -translate-x-2 group-hover:opacity-50 group-hover:translate-x-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
            </button>
          ))}
          
        </div>
      </aside>

      <div class="w-full lg:w-3/4 flex flex-col gap-4">
        {faqs.map((faq) => (
          <div 
            class="faq-item group/accordion border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 hover:bg-white dark:hover:bg-white/10 rounded-2xl transition-colors duration-300"
            data-cat={faq.categoryId}
          >
            <button class="accordion-header w-full flex items-center justify-between text-left p-5 md:p-6 focus:outline-none">
              <span class="text-base md:text-[17px] font-bold text-slate-800 dark:text-slate-100 pr-6 transition-colors duration-300 group-hover/accordion:text-[#10b981]">
                {faq.question}
              </span>
              <div class="w-8 h-8 shrink-0 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center text-slate-500 dark:text-slate-400 transition-transform duration-300 accordion-icon">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                </svg>
              </div>
            </button>
            
            <div class="accordion-content px-5 md:px-6">
              <div class="overflow-hidden">
                <p class="text-slate-600 dark:text-[#94a3b8] pb-6 leading-relaxed text-sm md:text-base">
                  {faq.answer}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  /* Ocultar barra de scroll en móviles */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* Animación suave de altura para el acordeón con Grid */
  .accordion-content {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }
  .accordion-content.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // --- LÓGICA DE FILTRADO POR CATEGORÍAS ---
    const catBtns = document.querySelectorAll('.cat-btn');
    const faqItems = document.querySelectorAll('.faq-item');

    // Clases de Tailwind para los estados
    const activeClasses = ['bg-[#10b981]/10', 'text-[#10b981]', 'border-[#10b981]/20'];
    const inactiveClasses = ['border-transparent', 'text-slate-500', 'dark:text-slate-400', 'hover:bg-slate-100', 'dark:hover:bg-white/5'];

    catBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        
        // 1. Resetear todos los botones a inactivos
        catBtns.forEach(b => {
          b.classList.remove(...activeClasses);
          b.classList.add(...inactiveClasses);
          
          const icon = b.querySelector('.arrow-icon');
          if (icon) {
            icon.classList.remove('opacity-100', 'translate-x-0');
            icon.classList.add('opacity-0', '-translate-x-2', 'group-hover:opacity-50', 'group-hover:translate-x-0');
          }
        });

        // 2. Activar el botón clicado
        btn.classList.remove(...inactiveClasses);
        btn.classList.add(...activeClasses);
        
        const activeIcon = btn.querySelector('.arrow-icon');
        if (activeIcon) {
          activeIcon.classList.remove('opacity-0', '-translate-x-2', 'group-hover:opacity-50', 'group-hover:translate-x-0');
          activeIcon.classList.add('opacity-100', 'translate-x-0');
        }

        // 3. Filtrar las preguntas
        const target = btn.getAttribute('data-target');
        
        faqItems.forEach(item => {
          const itemCat = item.getAttribute('data-cat');
          
          if (target === 'all' || itemCat === target) {
            item.style.display = 'block';
            item.animate([
              { opacity: 0, transform: 'translateY(10px)' },
              { opacity: 1, transform: 'translateY(0)' }
            ], { duration: 300, easing: 'ease-out' });
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    // --- LÓGICA DEL ACORDEÓN ---
    const headers = document.querySelectorAll('.accordion-header');

    headers.forEach(header => {
      header.addEventListener('click', () => {
        const content = header.nextElementSibling;
        const icon = header.querySelector('.accordion-icon');
        const questionText = header.querySelector('span');

        const isOpen = content?.classList.contains('is-open');

        // Cerrar todos los demás
        document.querySelectorAll('.accordion-content').forEach(otherContent => {
          otherContent.classList.remove('is-open');
        });
        document.querySelectorAll('.accordion-icon').forEach(otherIcon => {
          otherIcon.classList.remove('rotate-45', 'bg-[#10b981]', 'text-white');
          otherIcon.classList.add('bg-slate-200', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400');
        });
        document.querySelectorAll('.accordion-header span').forEach(otherText => {
          otherText.classList.remove('text-[#10b981]');
        });

        // Abrir si estaba cerrado
        if (!isOpen) {
          content?.classList.add('is-open');
          questionText?.classList.add('text-[#10b981]');
          
          icon?.classList.remove('bg-slate-200', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400');
          icon?.classList.add('rotate-45', 'bg-[#10b981]', 'text-white');
        }
      });
    });

    // Abrir el primero por defecto
    if(headers.length > 0) {
      headers[0].click();
    }

  });
</script>