---
// src/components/Header.astro
import navigationData from '../data/navigation.json';
const { links, buttons } = navigationData;
---

<!-- HEADER PRINCIPAL -->
<header id="main-header" class="w-full fixed top-0 left-0 z-50 transition-all duration-500 ease-in-out bg-transparent border-b border-transparent">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between transition-all duration-300">
    
    <!-- Lado Izquierdo: LOGO DINÁMICO -->
    <a href="/" class="flex items-center gap-3 group">
      <!-- Muestra este en Modo Claro -->
      <img src="/assets/icons/logocheka-light.svg" alt="Cheka Logo" class="w-28 h-auto dark:hidden transition-transform duration-300 group-hover:scale-105" />
      <!-- Muestra este en Modo Oscuro -->
      <img src="/assets/icons/logocheka-dark.svg" alt="Cheka Logo" class="w-28 h-auto hidden dark:block transition-transform duration-300 group-hover:scale-105" />
      
      <!-- NOTA: Si tu SVG ya incluye el texto "Cheka" borra el span de abajo. Si es solo el isotipo, déjalo -->
      <!-- <span class="text-slate-900 dark:text-white text-xl font-extrabold tracking-wide">Cheka</span> -->
    </a>

    <!-- Centro: LINKS DE NAVEGACIÓN (Desktop) -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        link.type === 'link' ? (
          <a href={link.url} class="text-sm font-bold text-slate-600 dark:text-slate-300 hover:text-cheka-primary dark:hover:text-cheka-primary transition-colors">
            {link.name}
          </a>
        ) : (
          <div class="relative group cursor-pointer">
            <div class="flex items-center gap-1 text-sm font-bold text-slate-600 dark:text-slate-300 group-hover:text-cheka-primary dark:group-hover:text-cheka-primary transition-colors py-2">
              {link.name}
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>
            <!-- Dropdown -->
            <div class="absolute top-full left-0 mt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
              <div class="bg-white dark:bg-cheka-dark-card border border-slate-200 dark:border-white/10 rounded-xl shadow-2xl p-2 flex flex-col gap-1">
                {link.items?.map((item) => (
                  <a href={item.url} class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-white/5 transition-colors group/item">
                    <div class={`w-10 h-10 rounded-lg flex items-center justify-center transition-colors ${item.colorTheme === 'green' ? 'bg-cheka-primary/10 text-cheka-primary' : 'bg-blue-500/10 text-blue-500'}`}>
                      {item.icon === 'book' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>}
                      {item.icon === 'code' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>}
                    </div>
                    <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-cheka-primary">{item.name}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        )
      ))}
    </nav>

    <!-- Lado Derecho: BOTONES CON ANIMACIÓN (Desktop) -->
    <div class="hidden md:flex items-center gap-4">
      <a href={buttons.login.url} class="text-sm font-bold text-slate-700 dark:text-white px-5 py-2.5 rounded-full border border-slate-300 dark:border-white/20 hover:border-slate-500 dark:hover:border-white/40 hover:scale-105 transition-all duration-300">
        {buttons.login.name}
      </a>
      
      <!-- Botón Registrarse con efecto brillo -->
      <a href={buttons.register.url} class="relative overflow-hidden group/btn text-sm font-bold text-white dark:text-cheka-dark-bg bg-cheka-primary px-6 py-2.5 rounded-full shadow-[0_0_15px_rgba(36,218,141,0.3)] hover:shadow-[0_0_25px_rgba(36,218,141,0.6)] hover:scale-105 transition-all duration-300">
        <span class="relative z-10">{buttons.register.name}</span>
        <!-- Elemento del brillo -->
        <div class="absolute inset-0 -translate-x-full group-hover/btn:translate-x-[300%] bg-gradient-to-r from-transparent via-white/40 to-transparent transition-transform duration-700 ease-in-out z-0"></div>
      </a>
    </div>

    <!-- Botón Hamburguesa (Móvil) -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-900 dark:text-white focus:outline-none hover:scale-110 transition-transform">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </button>
  </div>
</header>

<!-- MENÚ MÓVIL FULL SCREEN (Idéntico a la imagen) -->
<div id="mobile-menu-overlay" class="fixed inset-0 z-[100] bg-cheka-dark-bg opacity-0 pointer-events-none transition-opacity duration-300 md:hidden flex flex-col">
  
  <!-- Header del Menú Móvil -->
  <div class="flex items-center justify-between px-6 h-20 border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-cheka-primary rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-cheka-dark-bg" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
      </div>
      <span class="text-white text-xl font-bold">Cheka</span>
    </div>
    
    <!-- Botón X con borde -->
    <button id="mobile-close-btn" class="w-9 h-9 flex items-center justify-center rounded-lg border border-white/20 text-white hover:bg-white/10 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
  </div>

  <!-- Contenido del Menú Móvil -->
  <div class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-6">
    {links.map((link) => (
      link.type === 'link' ? (
        <a href={link.url} class="text-base font-bold text-slate-200 hover:text-cheka-primary transition-colors mobile-link">
          {link.name}
        </a>
      ) : (
        <div class="flex flex-col gap-4">
          <button class="mobile-dropdown-btn flex items-center justify-between w-full text-base font-bold text-slate-200">
            {link.name}
            <svg class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div class="mobile-dropdown-content hidden flex-col gap-4 pl-4 border-l border-white/10">
            {link.items?.map((item) => (
              <a href={item.url} class="flex items-center gap-3 text-sm font-bold text-slate-400 hover:text-white transition-colors mobile-link">
                {item.icon === 'book' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>}
                {item.icon === 'code' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>}
                {item.name}
              </a>
            ))}
          </div>
        </div>
      )
    ))}
    
    <!-- Separador -->
    <hr class="border-white/10 my-2" />

    <!-- Botones en Grilla (Idéntico a la imagen) -->
    <div class="grid grid-cols-2 gap-4">
      <a href={buttons.login.url} class="flex items-center justify-center text-sm font-bold text-white py-3.5 rounded-xl border border-white/20 bg-white/5 hover:bg-white/10 transition-colors">
        {buttons.login.name}
      </a>
      <a href={buttons.register.url} class="flex items-center justify-center text-sm font-bold text-cheka-dark-bg bg-cheka-primary py-3.5 rounded-xl shadow-[0_0_15px_rgba(36,218,141,0.2)]">
        {buttons.register.name}
      </a>
    </div>
  </div>
</div>

<script>
  // EFECTO GLASSMORPHISM EN SCROLL
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-white/80', 'dark:bg-cheka-dark-bg/80', 'backdrop-blur-md', 'border-slate-200', 'dark:border-white/10', 'shadow-sm');
      header?.classList.remove('bg-transparent', 'border-transparent');
    } else {
      header?.classList.remove('bg-white/80', 'dark:bg-cheka-dark-bg/80', 'backdrop-blur-md', 'border-slate-200', 'dark:border-white/10', 'shadow-sm');
      header?.classList.add('bg-transparent', 'border-transparent');
    }
  });

  // LÓGICA DEL MENÚ MÓVIL
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const overlay = document.getElementById('mobile-menu-overlay');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const dropdownBtns = document.querySelectorAll('.mobile-dropdown-btn');

  const toggleMenu = () => {
    const isClosed = overlay?.classList.contains('opacity-0');
    if (isClosed) {
      overlay?.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden'; // Evita scroll de fondo
    } else {
      overlay?.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }
  };

  mobileBtn?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

  // Acordeón para "Recursos" en móvil
  dropdownBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const content = target.nextElementSibling;
      const arrow = target.querySelector('svg');
      
      content?.classList.toggle('hidden');
      content?.classList.toggle('flex');
      arrow?.classList.toggle('rotate-180');
    });
  });
</script>