---
// src/components/Contact.astro
import contactData from '../data/contact.json';
const { header, form } = contactData;
---

<section id="contacto" class="relative py-24 md:py-32 bg-slate-50 dark:bg-[#0A0F1C] transition-colors duration-300 overflow-hidden">
  
  <!-- Efectos de Luces de Fondo (Similares al Hero) -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl h-[400px] bg-[#10b981]/20 dark:bg-[#10b981]/10 blur-[100px] rounded-full pointer-events-none z-0"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-blue-500/10 blur-[100px] rounded-full pointer-events-none z-0 hidden md:block"></div>

  <div id="contact-animated-wrapper" class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 opacity-0 translate-y-12 transition-all duration-1000 ease-[cubic-bezier(0.2,0.8,0.2,1)]">
    
    <!-- Encabezado de la sección -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#10b981]/10 border border-[#10b981]/20 text-[#10b981] text-sm font-bold mb-6 mx-auto shadow-[0_0_15px_rgba(16,185,129,0.15)]">
        {header.badge}
      </div>
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 dark:text-white tracking-tight mb-4">
        {header.title} 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#10b981] to-[#34d399] italic">
          {header.highlight}
        </span>
      </h2>
      
      <p class="max-w-2xl mx-auto text-base md:text-lg text-slate-600 dark:text-[#94a3b8] mb-6">
        {header.description}
      </p>

      <!-- Elemento de Urgencia (Pulsante) -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-orange-500/10 text-orange-600 dark:text-orange-400 text-sm font-semibold animate-pulse">
        <span>{header.urgency}</span>
      </div>
    </div>

    <!-- Tarjeta del Formulario (Glassmorphism) -->
    <div class="max-w-3xl mx-auto bg-white/80 dark:bg-[#0F172A]/80 backdrop-blur-xl border border-slate-200 dark:border-white/10 p-6 md:p-10 rounded-[32px] shadow-2xl dark:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
      
      <form class="flex flex-col gap-6" onsubmit="event.preventDefault(); alert('¡Gracias por registrarte! Nos pondremos en contacto pronto.');">
        
        <!-- Fila de 2 columnas (Nombre y Negocio) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <div class="flex flex-col gap-2">
            <label for="name" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">
              {form.name.label}
            </label>
            <input 
              type="text" 
              id="name" 
              required
              placeholder={form.name.placeholder}
              class="w-full bg-slate-50 dark:bg-[#0A0F1C] border border-slate-200 dark:border-white/10 text-slate-900 dark:text-white px-5 py-4 rounded-2xl focus:outline-none focus:ring-2 focus:ring-[#10b981]/50 focus:border-[#10b981] transition-all duration-300 placeholder:text-slate-400 dark:placeholder:text-slate-500"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="business" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">
              {form.business.label}
            </label>
            <input 
              type="text" 
              id="business" 
              required
              placeholder={form.business.placeholder}
              class="w-full bg-slate-50 dark:bg-[#0A0F1C] border border-slate-200 dark:border-white/10 text-slate-900 dark:text-white px-5 py-4 rounded-2xl focus:outline-none focus:ring-2 focus:ring-[#10b981]/50 focus:border-[#10b981] transition-all duration-300 placeholder:text-slate-400 dark:placeholder:text-slate-500"
            />
          </div>

        </div>

        <!-- Fila completa (Email) -->
        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">
            {form.email.label}
          </label>
          <input 
            type="email" 
            id="email" 
            required
            placeholder={form.email.placeholder}
            class="w-full bg-slate-50 dark:bg-[#0A0F1C] border border-slate-200 dark:border-white/10 text-slate-900 dark:text-white px-5 py-4 rounded-2xl focus:outline-none focus:ring-2 focus:ring-[#10b981]/50 focus:border-[#10b981] transition-all duration-300 placeholder:text-slate-400 dark:placeholder:text-slate-500"
          />
        </div>

        <!-- Botón Submit -->
        <button 
          type="submit" 
          class="relative overflow-hidden group w-full text-base md:text-lg font-bold text-white bg-gradient-to-r from-[#10b981] to-[#059669] py-4 rounded-2xl shadow-[0_0_20px_rgba(16,185,129,0.4)] hover:shadow-[0_0_30px_rgba(16,185,129,0.6)] hover:-translate-y-1 active:translate-y-0 active:scale-[0.98] transition-all duration-300 mt-2"
        >
          <span class="relative z-10">{form.submit}</span>
          <!-- Efecto de brillo barriendo el botón -->
          <div class="absolute inset-0 -translate-x-full group-hover:translate-x-[300%] bg-gradient-to-r from-transparent via-white/30 to-transparent transition-transform duration-1000 ease-in-out z-0"></div>
        </button>

        <!-- Disclaimer Footer -->
        <p class="text-center text-xs md:text-sm text-slate-500 dark:text-slate-400 mt-2">
          {form.footer}
        </p>

      </form>
    </div>
  </div>
</section>

<script>
  // Animación de entrada fluida (Una sola vez por sesión)
  document.addEventListener('DOMContentLoaded', () => {
    const contactWrapper = document.getElementById('contact-animated-wrapper');
    const hasAnimated = sessionStorage.getItem('contactSectionAnimated');

    if (hasAnimated) {
      contactWrapper?.classList.remove('opacity-0', 'translate-y-12');
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            contactWrapper?.classList.remove('opacity-0', 'translate-y-12');
            sessionStorage.setItem('contactSectionAnimated', 'true');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      
      if (contactWrapper) observer.observe(contactWrapper);
    }
  });
</script>