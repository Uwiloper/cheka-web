---
// src/components/Hero.astro
import heroData from '../data/hero.json';
import DashboardMock from './DashboardMock.astro';

const { badge, title, description, buttons, trust } = heroData;
---

<section class="relative w-full min-h-screen overflow-hidden pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-44 lg:pb-32 flex items-center bg-cheka-light-bg dark:bg-[#0A0F1C] transition-colors duration-300">
  
  <!-- ================= ONDAS DE FONDO ANIMADAS ================= -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <!-- Círculos de luz estáticos de apoyo -->
    <div class="absolute top-1/4 left-1/3 -translate-x-1/2 w-[600px] h-[600px] bg-[#10b981]/5 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-0 right-10 w-[500px] h-[500px] bg-[#3b82f6]/5 blur-[150px] rounded-full"></div>

    <!-- SVG Ondas -->
    <div class="absolute top-[30%] left-0 w-full opacity-30 dark:opacity-20">
      <svg class="w-full h-auto" viewBox="0 0 1440 300" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Onda 1 (Verde simulando Ingresos) -->
        <path class="wave-line-1" d="M-100 150 C 200 50, 400 250, 720 150 C 1040 50, 1240 250, 1540 150" stroke="url(#paint0_linear)" stroke-width="2" stroke-linecap="round"/>
        <!-- Onda 2 (Azul simulando Gastos) -->
        <path class="wave-line-2" d="M-100 200 C 250 280, 350 80, 720 180 C 1090 280, 1190 80, 1540 180" stroke="url(#paint1_linear)" stroke-width="1.5" stroke-linecap="round"/>
        <!-- Onda 3 (Sutil fondo) -->
        <path class="wave-line-3" d="M-100 100 C 150 250, 500 50, 720 120 C 940 190, 1300 50, 1540 120" stroke="url(#paint2_linear)" stroke-width="1" stroke-linecap="round"/>
        
        <defs>
          <linearGradient id="paint0_linear" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
            <stop stop-color="#10b981" stop-opacity="0" />
            <stop offset="0.5" stop-color="#10b981" stop-opacity="0.8" />
            <stop offset="1" stop-color="#10b981" stop-opacity="0" />
          </linearGradient>
          <linearGradient id="paint1_linear" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
            <stop stop-color="#60a5fa" stop-opacity="0" />
            <stop offset="0.5" stop-color="#60a5fa" stop-opacity="0.6" />
            <stop offset="1" stop-color="#60a5fa" stop-opacity="0" />
          </linearGradient>
          <linearGradient id="paint2_linear" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
            <stop stop-color="#a855f7" stop-opacity="0" />
            <stop offset="0.5" stop-color="#a855f7" stop-opacity="0.3" />
            <stop offset="1" stop-color="#a855f7" stop-opacity="0" />
          </linearGradient>
        </defs>
      </svg>
    </div>
  </div>

  <!-- Contenedor Principal (12 Columnas) -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-12 grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-8 items-center relative z-10 w-full">
    
    <!-- ================= LADO IZQUIERDO: Textos y CTA ================= -->
    <div class="lg:col-span-5 flex flex-col items-start space-y-7 text-left w-full max-w-2xl mx-auto lg:mx-0">
      
      <!-- Badge -->
      {badge !== "" && (
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#10b981]/10 border border-[#10b981]/20 text-[11px] font-bold text-[#10b981] shadow-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-[#10b981]"></span>
          {badge}
        </div>
      )}

      <!-- Título Principal -->
      <h1 class="text-[44px] leading-[1.05] sm:text-5xl md:text-[56px] font-black tracking-tight text-slate-900 dark:text-white">
        {title.prefix !== "" && <span>{title.prefix}</span>}
        
        <!-- Contenedor Typewriter -->
        {title.typewriter.length > 0 && (
          <span class="relative inline-block">
            <span id="typewriter" class="text-transparent bg-clip-text bg-gradient-to-r transition-all duration-300"></span>
            <span id="typewriter-cursor" class="animate-pulse -ml-1 opacity-80">|</span>
          </span>
        )}
        <br />
        <!-- Suffix en Cursiva -->
        {title.suffix !== "" && <span class="italic font-medium text-slate-700 dark:text-slate-200 block mt-2">{title.suffix}</span>}
      </h1>

      <!-- Descripción -->
      {description !== "" && (
        <p class="text-lg text-slate-600 dark:text-[#94a3b8] max-w-[90%] leading-relaxed font-medium">
          {description}
        </p>
      )}

      <!-- Botones -->
      {(buttons.primary.text !== "" || buttons.secondary.text !== "") && (
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto pt-4">
          
          {buttons.primary.text !== "" && (
            <a href={buttons.primary.url} class="group/btn relative overflow-hidden flex items-center justify-center text-[15px] font-bold text-white dark:text-[#0F172A] bg-[#10b981] px-8 py-3.5 rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.25)] hover:shadow-[0_0_30px_rgba(16,185,129,0.4)] hover:scale-105 transition-all duration-300 w-full sm:w-auto">
              <span class="relative z-10">{buttons.primary.text}</span>
              <!-- Resplandor Hover -->
              <div class="absolute inset-0 -translate-x-full group-hover/btn:translate-x-[300%] bg-gradient-to-r from-transparent via-white/40 to-transparent transition-transform duration-700 ease-in-out z-0"></div>
            </a>
          )}
          
          {buttons.secondary.text !== "" && (
            <a href={buttons.secondary.url} class="group/demo flex items-center justify-center text-[15px] font-bold text-slate-700 dark:text-white px-8 py-3.5 rounded-xl border border-slate-300 dark:border-white/10 hover:bg-slate-50 dark:hover:bg-white/5 hover:scale-105 transition-all duration-300 w-full sm:w-auto">
              {buttons.secondary.text}
            </a>
          )}
        </div>
      )}

      <!-- Prueba Social (Avatares apilados) -->
      {(trust.avatars.length > 0 || trust.text !== "") && (
        <div class="pt-6 flex items-center gap-4 w-full">
          {trust.avatars.length > 0 && (
            <div class="flex items-center">
              {trust.avatars.map((avatar, index) => (
                <div class={`w-10 h-10 rounded-full border-2 border-cheka-light-bg dark:border-[#0A0F1C] overflow-hidden shadow-sm ${index !== 0 ? '-ml-3' : ''}`}>
                  <img src={avatar} alt={`Avatar ${index + 1}`} class="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          )}
          <p class="text-[14px] text-slate-600 dark:text-[#94a3b8] font-medium m-0">
            {trust.highlight !== "" && <strong class="text-slate-900 dark:text-white font-bold">{trust.highlight}</strong>} {trust.text}
          </p>
        </div>
      )}
    </div>

    <!-- ================= LADO DERECHO: Dashboard ================= -->
    <div class="lg:col-span-7 relative w-[95%] sm:w-[90%] lg:w-full mx-auto flex justify-center lg:justify-end items-start mt-4 lg:mt-0">
      <DashboardMock />
    </div>

  </div>
</section>

<!-- Script del Typewriter -->
<script define:vars={{ words: title.typewriter }}>
  if (typeof window !== 'undefined' && words && words.length > 0) {
    const twEl = document.getElementById('typewriter');
    const cursorEl = document.getElementById('typewriter-cursor');
    
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function typeEffect() {
      const currentWord = words[wordIndex];
      const text = currentWord.text;
      
      if (twEl && cursorEl) {
        twEl.style.backgroundImage = `linear-gradient(to right, ${currentWord.color1}, ${currentWord.color2})`;
        cursorEl.style.color = currentWord.cursorColor;
      }

      if (isDeleting) {
        twEl.textContent = text.substring(0, charIndex - 1);
        charIndex--;
      } else {
        twEl.textContent = text.substring(0, charIndex + 1);
        charIndex++;
      }

      let typingSpeed = isDeleting ? 40 : 100;

      if (!isDeleting && charIndex === text.length) {
        typingSpeed = 2500; 
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        typingSpeed = 400; 
      }

      setTimeout(typeEffect, typingSpeed);
    }

    setTimeout(typeEffect, 800);
  }
</script>

<style is:global>
  /* Animación Suave de las Ondas SVG */
  .wave-line-1 { animation: waveSlide 15s linear infinite alternate; }
  .wave-line-2 { animation: waveSlide 20s linear infinite alternate-reverse; }
  .wave-line-3 { animation: waveSlide 25s linear infinite alternate; }

  @keyframes waveSlide {
    0% { transform: translateX(-5%); }
    100% { transform: translateX(5%); }
  }
</style>