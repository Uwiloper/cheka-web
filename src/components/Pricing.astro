---
// src/components/Pricing.astro
import pricingData from '../data/pricing.json';
const { header, plans } = pricingData;

// Duplicamos el array 3 veces para crear el efecto de scroll infinito
const displayPlans = [...plans, ...plans, ...plans];
---

<section id="precios" class="relative py-12 md:py-20 bg-slate-50 dark:bg-[#0A0F1C] transition-colors duration-300 overflow-hidden">
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-[#10b981]/5 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-[1400px] mx-auto relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-8 md:mb-10 px-4">
      <h2 class="text-2xl md:text-4xl font-black text-slate-900 dark:text-white tracking-tight mb-3">
        {header.title}
      </h2>
      <p class="text-sm md:text-base text-slate-600 dark:text-[#94a3b8] mb-6">
        {header.description}
      </p>

      <div class="flex items-center justify-center gap-3 md:gap-4">
        <span class="text-xs md:text-sm font-bold text-slate-700 dark:text-slate-300 transition-colors" id="label-mensual">Mensual</span>
        
        <button id="billing-toggle" class="relative w-12 h-6 md:w-14 md:h-7 rounded-full bg-slate-300 dark:bg-slate-700 transition-colors duration-300 focus:outline-none shadow-inner">
          <div id="toggle-circle" class="absolute top-1 left-1 w-4 h-4 md:w-5 md:h-5 rounded-full bg-white dark:bg-[#0F172A] shadow-md transform transition-transform duration-300 flex items-center justify-center translate-x-0">
            <span class="w-1.5 h-1.5 rounded-full bg-[#10b981] opacity-0 transition-opacity duration-300" id="toggle-dot"></span>
          </div>
        </button>
        
        <div class="flex items-center gap-2">
          <span class="text-xs md:text-sm font-bold text-slate-500 dark:text-slate-400 transition-colors" id="label-anual">Anual</span>
          <span class="px-2 py-0.5 rounded-md bg-[#10b981]/10 text-[#10b981] text-[8px] md:text-[9px] font-black uppercase tracking-wider">Ahorra 20%</span>
        </div>
      </div>
    </div>

    <div class="relative w-full group/carousel">
      
      <button id="btn-prev" class="absolute left-2 md:left-8 top-1/2 -translate-y-1/2 z-40 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-white/90 dark:bg-slate-800/90 backdrop-blur-md border border-slate-200 dark:border-slate-700 shadow-lg text-slate-700 dark:text-white hover:bg-white dark:hover:bg-slate-700 hover:scale-110 transition-transform focus:outline-none">
        <svg class="w-5 h-5 md:w-6 md:h-6 pr-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
      </button>

      <div 
        id="pricing-track" 
        class="flex gap-4 md:gap-6 overflow-x-hidden no-scrollbar px-[10vw] md:px-[20vw] pb-12 pt-12 items-stretch cursor-grab active:cursor-grabbing select-none [mask-image:linear-gradient(to_right,transparent_0%,black_10%,black_90%,transparent_100%)] md:[mask-image:linear-gradient(to_right,transparent_0%,black_15%,black_85%,transparent_100%)]"
      >
        {displayPlans.map((plan) => (
          <div class={`plan-card relative group flex flex-col shrink-0 w-[75vw] sm:w-[280px] md:w-[320px] rounded-3xl transition-all duration-500 z-10
            ${plan.isPopular ? 'lg:-translate-y-2 lg:hover:-translate-y-4 is-popular' : 'shadow-xl lg:hover:-translate-y-1 bg-white dark:bg-[#111827] border border-slate-200 dark:border-white/5'}
          `}>
            
            {/* Borde Animado */}
            {plan.isPopular && (
              <div class="absolute -inset-[2px] rounded-[1.5rem] bg-gradient-to-br from-[#10b981] via-[#10b981] to-[#10b981] bg-[length:200%_200%] animate-gradient-xy z-0"></div>
            )}

            {/* ETIQUETA REUBICADA AQUÍ (Fuera del overflow-hidden interno) */}
            {plan.isPopular && (
              <div class="absolute top-0 inset-x-0 flex justify-center z-30 -translate-y-1/2">
                <span class="bg-gradient-to-r from-[#10b981] to-[#059669] text-white text-[9px] md:text-[10px] font-black uppercase tracking-widest py-1.5 px-4 rounded-full shadow-lg">
                  {plan.badge}
                </span>
              </div>
            )}

            {/* Contenedor interno (con overflow-hidden para el brillo) */}
            <div class={`relative z-10 flex flex-col h-full p-5 md:p-6 rounded-[calc(1.5rem-2px)] overflow-hidden pointer-events-none
              ${plan.isPopular ? 'bg-white dark:bg-[#1E293B] shadow-[0_20px_50px_rgba(16,185,129,0.15)] dark:shadow-[0_20px_50px_rgba(16,185,129,0.05)]' : ''}
            `}>
              
              <div class="absolute inset-0 -translate-x-full group-hover:animate-shine bg-gradient-to-r from-transparent via-white/5 to-transparent z-0"></div>

              <div class={`mb-4 relative z-10 shrink-0 ${plan.isPopular ? 'mt-4' : 'mt-0'}`}>
                <h3 class="text-lg md:text-xl font-bold text-slate-900 dark:text-white mb-1.5">{plan.name}</h3>
                <p class="text-xs md:text-sm text-slate-500 dark:text-[#94a3b8] h-8 md:h-10 line-clamp-2">{plan.description}</p>
              </div>

              <div class="mb-5 relative z-10 shrink-0">
                <div class="flex items-baseline gap-1 h-[40px] md:h-[48px]">
                  {plan.priceMonthly !== "Hablemos" && (
                    <span class={`text-lg font-bold ${plan.isPopular ? 'text-[#10b981]' : 'text-slate-400 dark:text-slate-500'}`}>S/</span>
                  )}
                  
                  <span 
                    class={`text-3xl md:text-4xl font-black tracking-tight price-amount transition-all duration-300 inline-block
                      ${plan.isPopular 
                        ? 'text-transparent bg-clip-text animate-text-sweep bg-gradient-to-r from-[#10b981] via-[#6ee7b7] to-[#10b981] dark:from-[#10b981] dark:via-[#a7f3d0] dark:to-[#10b981] bg-[length:200%_auto]' 
                        : 'text-slate-900 dark:text-white'}
                    `} 
                    data-monthly={plan.priceMonthly} 
                    data-annual={plan.priceAnnual}
                  >
                    {plan.priceMonthly}
                  </span>
                </div>

                {plan.priceMonthly !== "Hablemos" && (
                  <span class="text-xs font-medium text-slate-500 dark:text-[#64748b] price-period transition-opacity duration-300">/mes</span>
                )}
                {plan.priceMonthly === "Hablemos" && (
                  <span class="text-xs font-medium text-slate-500 dark:text-[#64748b] block mt-1">Conversemos sobre tu negocio</span>
                )}
              </div>

              <ul class="flex-1 relative z-10 space-y-2.5 mb-6">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2.5 text-xs md:text-sm">
                    <div class="shrink-0 mt-0.5">
                      {feature.included ? (
                        <svg class={`w-4 h-4 md:w-5 md:h-5 ${feature.highlight ? 'text-[#10b981]' : 'text-[#10b981]'}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      ) : (
                        <svg class="w-4 h-4 md:w-5 md:h-5 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                      )}
                    </div>
                    <span class={`font-medium ${feature.included ? (feature.highlight ? 'text-slate-900 dark:text-white font-bold' : 'text-slate-700 dark:text-slate-300') : 'text-slate-400 dark:text-slate-600 line-through'}`}>
                      {feature.name}
                    </span>
                  </li>
                ))}
              </ul>

              <div class="mt-auto relative z-10 shrink-0 pointer-events-auto">
                {plan.button.style === 'primary' ? (
                  <a 
                    href={plan.button.urlMonthly} 
                    data-monthly-url={plan.button.urlMonthly}
                    data-annual-url={plan.button.urlAnnual}
                    class="plan-action-btn group/btn relative overflow-hidden flex items-center justify-center text-[13px] md:text-[14px] font-bold text-white dark:text-[#0F172A] bg-[#10b981] w-full py-3 rounded-xl shadow-[0_0_15px_rgba(16,185,129,0.25)] hover:shadow-[0_0_25px_rgba(16,185,129,0.4)] hover:-translate-y-1 transition-all duration-300"
                  >
                    <span class="relative z-10">{plan.button.text}</span>
                    <div class="absolute inset-0 -translate-x-full group-hover/btn:translate-x-[300%] bg-gradient-to-r from-transparent via-white/40 to-transparent transition-transform duration-700 ease-in-out z-0"></div>
                  </a>
                ) : (
                  <a 
                    href={plan.button.urlMonthly} 
                    data-monthly-url={plan.button.urlMonthly}
                    data-annual-url={plan.button.urlAnnual}
                    class="plan-action-btn group/demo flex items-center justify-center text-[13px] md:text-[14px] font-bold text-slate-700 dark:text-white w-full py-3 rounded-xl border border-slate-300 dark:border-white/10 hover:bg-slate-50 dark:hover:bg-white/5 hover:-translate-y-1 transition-all duration-300"
                  >
                    {plan.button.text}
                  </a>
                )}
              </div>

            </div>
          </div>
        ))}
      </div>

      <button id="btn-next" class="absolute right-2 md:right-8 top-1/2 -translate-y-1/2 z-40 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-white/90 dark:bg-slate-800/90 backdrop-blur-md border border-slate-200 dark:border-slate-700 shadow-lg text-slate-700 dark:text-white hover:bg-white dark:hover:bg-slate-700 hover:scale-110 transition-transform focus:outline-none">
        <svg class="w-5 h-5 md:w-6 md:h-6 pl-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
      </button>

    </div>

  </div>
</section>

<style is:global>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  @keyframes shine {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .animate-shine { animation: shine 1.5s ease-in-out forwards; }

  @keyframes gradient-xy {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-xy { animation: gradient-xy 3s ease infinite; }

  @keyframes text-sweep {
    to { background-position: 200% center; }
  }
  .animate-text-sweep { animation: text-sweep 3s linear infinite; }
</style>

<script>
  if (typeof window !== 'undefined') {
    
    // --- LÓGICA DEL TOGGLE ---
    const toggleBtn = document.getElementById('billing-toggle');
    const toggleCircle = document.getElementById('toggle-circle');
    const toggleDot = document.getElementById('toggle-dot');
    const labelMensual = document.getElementById('label-mensual');
    const labelAnual = document.getElementById('label-anual');
    const priceAmounts = document.querySelectorAll('.price-amount');
    const pricePeriods = document.querySelectorAll('.price-period');
    const planActionBtns = document.querySelectorAll('.plan-action-btn');

    let isAnnual = false;
    const isMobile = window.innerWidth < 768;
    const toggleTranslate = isMobile ? 'translate-x-6' : 'translate-x-7';

    toggleBtn?.addEventListener('click', () => {
      isAnnual = !isAnnual;
      
      if (isAnnual) {
        toggleCircle?.classList.replace('translate-x-0', toggleTranslate);
        toggleBtn?.classList.add('bg-[#10b981]');
        toggleBtn?.classList.remove('bg-slate-300', 'dark:bg-slate-700');
        toggleDot?.classList.remove('opacity-0');
        labelMensual?.classList.replace('text-slate-700', 'text-slate-500');
        labelMensual?.classList.replace('dark:text-slate-300', 'dark:text-slate-400');
        labelAnual?.classList.replace('text-slate-500', 'text-slate-700');
        labelAnual?.classList.replace('dark:text-slate-400', 'dark:text-slate-300');
      } else {
        toggleCircle?.classList.replace(toggleTranslate, 'translate-x-0');
        toggleBtn?.classList.remove('bg-[#10b981]');
        toggleBtn?.classList.add('bg-slate-300', 'dark:bg-slate-700');
        toggleDot?.classList.add('opacity-0');
        labelMensual?.classList.replace('text-slate-500', 'text-slate-700');
        labelMensual?.classList.replace('dark:text-slate-400', 'dark:text-slate-300');
        labelAnual?.classList.replace('text-slate-700', 'text-slate-500');
        labelAnual?.classList.replace('dark:text-slate-300', 'dark:text-slate-400');
      }

      priceAmounts.forEach(el => {
        el.classList.add('opacity-0', '-translate-y-3');
        setTimeout(() => {
          const monthly = el.getAttribute('data-monthly');
          const annual = el.getAttribute('data-annual');
          el.innerHTML = isAnnual ? annual : monthly;
          el.classList.remove('-translate-y-3');
          el.classList.add('translate-y-3');
          requestAnimationFrame(() => el.classList.remove('opacity-0', 'translate-y-3'));
        }, 150);
      });

      pricePeriods.forEach(el => {
        el.classList.add('opacity-0');
        setTimeout(() => {
          el.innerHTML = isAnnual ? '/año' : '/mes';
          el.classList.remove('opacity-0');
        }, 150);
      });

      planActionBtns.forEach(btn => {
        const urlMonthly = btn.getAttribute('data-monthly-url');
        const urlAnnual = btn.getAttribute('data-annual-url');
        if(urlMonthly && urlAnnual) btn.setAttribute('href', isAnnual ? urlAnnual : urlMonthly);
      });
    });


    // --- LÓGICA DEL CARRUSEL ---
    const track = document.getElementById('pricing-track');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');

    if (track) {
      const getResetPoint = () => track.scrollWidth / 3;

      const popularCards = track.querySelectorAll('.is-popular');
      if (popularCards.length >= 2) {
        const target = popularCards[1]; 
        track.scrollLeft = target.offsetLeft - (track.clientWidth / 2) + (target.clientWidth / 2);
      }

      function checkBoundary() {
        if (track.scrollLeft <= 0) {
          track.scrollLeft += getResetPoint();
        } else if (track.scrollLeft >= getResetPoint() * 2) {
          track.scrollLeft -= getResetPoint();
        }
      }

      let isDown = false;
      let startX;
      let velX = 0;
      let momentumId;
      let isDragging = false;

      function beginMomentum() {
        track.scrollLeft -= velX;
        checkBoundary();
        velX *= 0.95; 
        if (Math.abs(velX) > 0.5) {
          momentumId = requestAnimationFrame(beginMomentum);
        }
      }

      track.addEventListener('click', (e) => {
        if (isDragging) {
          e.preventDefault();
          e.stopPropagation();
        }
      });

      track.addEventListener('mousedown', (e) => {
        isDown = true;
        isDragging = false;
        cancelAnimationFrame(momentumId);
        startX = e.pageX;
        velX = 0;
      });

      track.addEventListener('mouseleave', () => {
        if (!isDown) return;
        isDown = false;
        beginMomentum();
      });

      track.addEventListener('mouseup', () => {
        if (!isDown) return;
        isDown = false;
        beginMomentum();
        setTimeout(() => isDragging = false, 50);
      });

      track.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX;
        const dist = x - startX;
        if (Math.abs(dist) > 5) isDragging = true; 
        velX = dist * 1.5;
        track.scrollLeft -= velX;
        checkBoundary();
        startX = x;
      });

      track.addEventListener('touchstart', (e) => {
        isDown = true;
        isDragging = false;
        cancelAnimationFrame(momentumId);
        startX = e.touches[0].pageX;
        velX = 0;
      }, { passive: true });

      track.addEventListener('touchend', () => {
        if (!isDown) return;
        isDown = false;
        beginMomentum();
        setTimeout(() => isDragging = false, 50);
      });

      track.addEventListener('touchmove', (e) => {
        if (!isDown) return;
        const x = e.touches[0].pageX;
        const dist = x - startX;
        if (Math.abs(dist) > 5) isDragging = true;
        velX = dist * 1.5;
        track.scrollLeft -= velX;
        checkBoundary();
        startX = x;
      }, { passive: true });

      function slideBy(amount) {
        cancelAnimationFrame(momentumId);
        track.scrollBy({ left: amount, behavior: 'smooth' });
        setTimeout(checkBoundary, 400); 
      }

      btnPrev?.addEventListener('click', () => {
        const card = track.querySelector('.plan-card');
        const scrollAmount = card ? card.clientWidth + 24 : 320;
        slideBy(-scrollAmount);
      });

      btnNext?.addEventListener('click', () => {
        const card = track.querySelector('.plan-card');
        const scrollAmount = card ? card.clientWidth + 24 : 320;
        slideBy(scrollAmount);
      });
    }
  }
</script>