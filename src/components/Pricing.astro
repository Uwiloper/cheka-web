---
// src/components/Pricing.astro
import pricingData from '../data/pricing.json';
const { header, plans } = pricingData;
---

<section id="precios" class="relative py-24 bg-slate-50 dark:bg-[#0A0F1C] transition-colors duration-300 overflow-hidden">
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-[#10b981]/5 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight mb-4">
        {header.title}
      </h2>
      <p class="text-lg text-slate-600 dark:text-[#94a3b8] mb-10">
        {header.description}
      </p>

      <div class="flex items-center justify-center gap-4">
        <span class="text-sm font-bold text-slate-700 dark:text-slate-300 transition-colors" id="label-mensual">Mensual</span>
        
        <button id="billing-toggle" class="relative w-16 h-8 rounded-full bg-slate-300 dark:bg-slate-700 transition-colors duration-300 focus:outline-none shadow-inner">
          <div id="toggle-circle" class="absolute top-1 left-1 w-6 h-6 rounded-full bg-white dark:bg-[#0F172A] shadow-md transform transition-transform duration-300 flex items-center justify-center translate-x-0">
            <span class="w-2 h-2 rounded-full bg-[#10b981] opacity-0 transition-opacity duration-300" id="toggle-dot"></span>
          </div>
        </button>
        
        <div class="flex items-center gap-2">
          <span class="text-sm font-bold text-slate-500 dark:text-slate-400 transition-colors" id="label-anual">Anual</span>
          <span class="px-2 py-0.5 rounded-md bg-[#10b981]/10 text-[#10b981] text-[10px] font-black uppercase tracking-wider">Ahorra 20%</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 justify-center gap-8 max-w-7xl mx-auto items-stretch auto-rows-fr [grid-auto-flow:dense]">
      {plans.map((plan) => (
        <div class={`relative group flex flex-col h-full rounded-3xl transition-all duration-500 z-10
          ${plan.isPopular ? 'lg:-translate-y-4 lg:hover:-translate-y-6 md:col-span-2 lg:col-span-1 max-w-md mx-auto w-full' : 'shadow-xl lg:hover:-translate-y-2 max-w-md mx-auto w-full bg-white dark:bg-[#111827] border border-slate-200 dark:border-white/5'}
        `}>
          
          {/* Fondo Animado para el Borde del Plan Popular */}
          {plan.isPopular && (
            <div class="absolute -inset-[2px] rounded-[1.5rem] bg-gradient-to-br from-[#10b981] via-[#10b981] to-[#10b981] bg-[length:200%_200%] animate-gradient-xy z-0"></div>
          )}

          {/* Contenedor Interno de la Tarjeta */}
          <div class={`relative z-10 flex flex-col h-full p-8 rounded-[calc(1.5rem-2px)] overflow-hidden
            ${plan.isPopular ? 'bg-white dark:bg-[#1E293B] shadow-[0_20px_50px_rgba(16,185,129,0.15)] dark:shadow-[0_20px_50px_rgba(16,185,129,0.05)]' : ''}
          `}>
            
            {/* Destello de fondo general al hacer hover */}
            <div class="absolute inset-0 -translate-x-full group-hover:animate-shine bg-gradient-to-r from-transparent via-white/5 to-transparent pointer-events-none z-0"></div>

            {/* Badge de Popular */}
            {plan.isPopular && (
              <div class="absolute top-0 inset-x-0 flex justify-center z-20">
                <span class="bg-gradient-to-r from-[#10b981] to-[#059669] text-white text-[10px] font-black uppercase tracking-widest py-1 px-4 rounded-b-xl shadow-md">
                  {plan.badge}
                </span>
              </div>
            )}

            {/* Cabecera del Plan */}
            <div class="mb-8 relative z-10 mt-2 shrink-0">
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{plan.name}</h3>
              <p class="text-sm text-slate-500 dark:text-[#94a3b8] h-10 line-clamp-2">{plan.description}</p>
            </div>

            {/* Precios */}
            <div class="mb-8 relative z-10 shrink-0">
              <div class="flex items-baseline gap-1 h-[48px] md:h-[60px]">
                {plan.priceMonthly !== "Hablemos" && <span class="text-2xl font-bold text-slate-400 dark:text-slate-500">S/</span>}
                <span class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight price-amount transition-all duration-300 inline-block" data-monthly={plan.priceMonthly} data-annual={plan.priceAnnual}>
                  {plan.priceMonthly}
                </span>
              </div>
              {plan.priceMonthly !== "Hablemos" && (
                <span class="text-sm font-medium text-slate-500 dark:text-[#64748b] price-period transition-opacity duration-300">/mes</span>
              )}
              {plan.priceMonthly === "Hablemos" && (
                <span class="text-sm font-medium text-slate-500 dark:text-[#64748b] block mt-1">Conversemos sobre tu negocio</span>
              )}
            </div>

            {/* Características */}
            <ul class="space-y-4 mb-8 flex-1 relative z-10">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm">
                  <div class="shrink-0 mt-0.5">
                    {feature.included ? (
                      <svg class={`w-5 h-5 ${feature.highlight ? 'text-[#10b981]' : 'text-[#10b981]'}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                    ) : (
                      <svg class="w-5 h-5 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                    )}
                  </div>
                  <span class={`font-medium ${feature.included ? (feature.highlight ? 'text-slate-900 dark:text-white font-bold' : 'text-slate-700 dark:text-slate-300') : 'text-slate-400 dark:text-slate-600 line-through'}`}>
                    {feature.name}
                  </span>
                </li>
              ))}
            </ul>

            {/* Botones Actualizados */}
            <div class="mt-auto relative z-10 shrink-0">
              {plan.button.style === 'primary' ? (
                <a href={plan.button.url} class="group/btn relative overflow-hidden flex items-center justify-center text-[15px] font-bold text-white dark:text-[#0F172A] bg-[#10b981] w-full py-3.5 rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.25)] hover:shadow-[0_0_30px_rgba(16,185,129,0.4)] hover:scale-105 transition-all duration-300">
                  <span class="relative z-10">{plan.button.text}</span>
                  <div class="absolute inset-0 -translate-x-full group-hover/btn:translate-x-[300%] bg-gradient-to-r from-transparent via-white/40 to-transparent transition-transform duration-700 ease-in-out z-0"></div>
                </a>
              ) : (
                <a href={plan.button.url} class="group/demo flex items-center justify-center text-[15px] font-bold text-slate-700 dark:text-white w-full py-3.5 rounded-xl border border-slate-300 dark:border-white/10 hover:bg-slate-50 dark:hover:bg-white/5 hover:scale-105 transition-all duration-300">
                  {plan.button.text}
                </a>
              )}
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style is:global>
  /* Destello general de la tarjeta */
  @keyframes shine {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .animate-shine {
    animation: shine 1.5s ease-in-out forwards;
  }

  /* Animación del borde del plan popular */
  @keyframes gradient-xy {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-xy {
    animation: gradient-xy 3s ease infinite;
  }
</style>

<script>
  if (typeof window !== 'undefined') {
    const toggleBtn = document.getElementById('billing-toggle');
    const toggleCircle = document.getElementById('toggle-circle');
    const toggleDot = document.getElementById('toggle-dot');
    const labelMensual = document.getElementById('label-mensual');
    const labelAnual = document.getElementById('label-anual');
    const priceAmounts = document.querySelectorAll('.price-amount');
    const pricePeriods = document.querySelectorAll('.price-period');

    let isAnnual = false;

    toggleBtn?.addEventListener('click', () => {
      isAnnual = !isAnnual;
      
      // Animar el botón Toggle
      if (isAnnual) {
        toggleCircle?.classList.replace('translate-x-0', 'translate-x-8');
        toggleBtn?.classList.add('bg-[#10b981]');
        toggleBtn?.classList.remove('bg-slate-300', 'dark:bg-slate-700');
        toggleDot?.classList.remove('opacity-0');
        
        labelMensual?.classList.replace('text-slate-700', 'text-slate-500');
        labelMensual?.classList.replace('dark:text-slate-300', 'dark:text-slate-400');
        labelAnual?.classList.replace('text-slate-500', 'text-slate-700');
        labelAnual?.classList.replace('dark:text-slate-400', 'dark:text-slate-300');
      } else {
        toggleCircle?.classList.replace('translate-x-8', 'translate-x-0');
        toggleBtn?.classList.remove('bg-[#10b981]');
        toggleBtn?.classList.add('bg-slate-300', 'dark:bg-slate-700');
        toggleDot?.classList.add('opacity-0');

        labelMensual?.classList.replace('text-slate-500', 'text-slate-700');
        labelMensual?.classList.replace('dark:text-slate-400', 'dark:text-slate-300');
        labelAnual?.classList.replace('text-slate-700', 'text-slate-500');
        labelAnual?.classList.replace('dark:text-slate-300', 'dark:text-slate-400');
      }

      // Actualizar precios y periodos con una transición fluida en Y
      priceAmounts.forEach(el => {
        el.classList.add('opacity-0', '-translate-y-3');
        
        setTimeout(() => {
          const monthly = el.getAttribute('data-monthly');
          const annual = el.getAttribute('data-annual');
          el.innerHTML = isAnnual ? annual : monthly;
          
          el.classList.remove('-translate-y-3');
          el.classList.add('translate-y-3'); // Reset de posición
          
          requestAnimationFrame(() => {
            el.classList.remove('opacity-0', 'translate-y-3');
          });
        }, 150);
      });

      pricePeriods.forEach(el => {
        el.classList.add('opacity-0');
        setTimeout(() => {
          el.innerHTML = isAnnual ? '/año' : '/mes';
          el.classList.remove('opacity-0');
        }, 150);
      });

    });
  }
</script>